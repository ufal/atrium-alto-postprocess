[run]
source = .
omit =
    tests/*
    setup/*
    service/*
    venv/*
    .venv/*
    *_paradata.py
    para_licenses.py

[report]
# Ratchet: fast-lane baseline measured 53% (2026-07-16, issue atrium-project#10)
fail_under = 50
show_missing = True
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    pass
    except ImportError:
